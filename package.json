{
  "name": "shanlic-life-tracker-system",
  "version": "1.6.5",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dsh0205/SLTS.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && npm run build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "check:modules": "node scripts/check-module-consistency.mjs",
    "verify": "npm run check:modules && npm run build",
    "type-check": "vue-tsc --build",
    "electron": "node electron/launch.cjs .",
    "electron:dev": "wait-on tcp:127.0.0.1:5173 && node electron/launch.cjs .",
    "desktop:dev": "concurrently -k \"npm run dev -- --host 127.0.0.1 --strictPort\" \"npm run electron:dev\"",
    "desktop:build": "npm run build && electron-builder",
    "desktop:release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-tsc": "^3.2.5",
    "wait-on": "^8.0.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.shanlic.life-tracker",
    "productName": "SHANLIC LIFE TRACKER SYSTEM",
    "icon": "electron/assets/icon-256.png",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "icon": "electron/assets/icon-256.png",
      "executableName": "SHANLIC LIFE TRACKER SYSTEM",
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Dsh0205",
        "repo": "SLTS"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SHANLIC LIFE TRACKER SYSTEM"
    }
  }
}
